    col = row['col']
    if col == 'pdays':
        # Кліпуємо лише не-sentinel значення
        mask = train[col] < 999
        train.loc[mask, col] = train.loc[mask, col].clip(upper=row['upper_bound'])
    else:
        train[col] = train[col].clip(upper=row['upper_bound'])


